<Window x:Class="DocBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DocBuilder.WPF.ViewModels"
        xmlns:models="clr-namespace:DocBuilder.Models"
        Title="Documentation Builder" Height="700" Width="1100"
        Background="#F5F5F7">

  <Window.Resources>
    <DataTemplate DataType="{x:Type models:DocSection}">
      <Border Background="White" CornerRadius="8" Margin="0,0,0,12" Padding="15" 
                BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBlock Text="{Binding Type}" VerticalAlignment="Top" Margin="0,8,0,0"
                           FontWeight="Bold" Foreground="#667eea" FontSize="11"/>

          <TextBox Grid.Column="1" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" 
                         AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0" 
                         FontSize="14" Foreground="#2D3748" Padding="5"
                         MinWidth="200" Background="Transparent"/>

          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
            <Button Content="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
            Click="MoveSectionUp_Click" Background="Transparent" 
            Foreground="#4A5568" Margin="2,0" ToolTip="Move Up" Cursor="Hand"/>

            <Button Content="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
            Click="MoveSectionDown_Click" Background="Transparent" 
            Foreground="#4A5568" Margin="2,0" ToolTip="Move Down" Cursor="Hand"/>

            <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
            Click="RemoveSection_Click" Background="Transparent" 
            Foreground="#E53E3E" Margin="10,0,0,0" Cursor="Hand" ToolTip="Delete"/>
          </StackPanel>
          
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="250"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="White" BorderBrush="#EEE" BorderThickness="0,0,1,0">
      <Grid Margin="15">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="PAGES" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding Pages}" SelectedItem="{Binding CurrentPage}" 
                         BorderThickness="0" Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="2" Content="+ New Page" Background="#667eea" Foreground="White" Padding="10" BorderThickness="0"/>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Margin="30">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="0,0,0,20">
        <TextBox Text="{Binding CurrentPage.Title, UpdateSourceTrigger=PropertyChanged}" 
                         FontSize="28" FontWeight="Bold" BorderThickness="0,0,0,1" Background="Transparent" Padding="0,5"/>
        <TextBlock Text="{Binding CurrentPage.FileName}" Foreground="#AAA" FontSize="12" Margin="0,5,0,0"/>
      </StackPanel>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding CurrentPage.Sections}"/>
      </ScrollViewer>

      <Border Grid.Row="2" Padding="20,10" Background="White" CornerRadius="10" Margin="0,20,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <Button Content="H1" Command="{Binding AddSectionCommand}" CommandParameter="H1" Margin="3" Width="40"/>
          <Button Content="H2" Command="{Binding AddSectionCommand}" CommandParameter="H2" Margin="3" Width="40"/>
          <Button Content="H3" Command="{Binding AddSectionCommand}" CommandParameter="H3" Margin="3" Width="40"/>

          <Separator Width="10" Background="Transparent"/>

          <Button Content="Paragraph" Command="{Binding AddSectionCommand}" CommandParameter="Paragraph" Margin="3" Padding="10,5"/>
          <Button Content="Code Block" Command="{Binding AddSectionCommand}" CommandParameter="Code" Margin="3" Padding="10,5"/>
          <Button Content="Image Link" Command="{Binding AddSectionCommand}" CommandParameter="Image" Margin="3" Padding="10,5"/>

          <Separator Width="20" Background="Transparent"/>

          <Button Content="PUBLISH TO IIS" Command="{Binding PublishCommand}" 
            Background="#10B981" Foreground="White" FontWeight="Bold" Padding="20,8"/>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>