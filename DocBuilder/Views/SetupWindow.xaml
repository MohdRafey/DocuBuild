<Window x:Class="DocBuilder.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Documentation Setup" Height="400" Width="600"
        WindowStartupLocation="CenterScreen" Background="#F5F5F7">

  <StackPanel Margin="40" VerticalAlignment="Center">
    <TextBlock Text="Welcome to DocBuilder" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
    <TextBlock Text="How would you like to start?" Foreground="#666" Margin="0,0,0,30"/>

    <UniformGrid Columns="2" Height="120">
      <Button Click="NewProject_Click" Margin="10" Background="White">
        <StackPanel>
          <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="24" Margin="0,0,0,10" HorizontalAlignment="Center"/>
          <TextBlock Text="Create New Project" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        </StackPanel>
      </Button>

      <Button Click="OpenExisting_Click" Margin="10" Background="White">
        <StackPanel>
          <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="24" Margin="0,0,0,10" HorizontalAlignment="Center"/>
          <TextBlock Text="Open Existing Site" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        </StackPanel>
      </Button>
    </UniformGrid>

    <CheckBox x:Name="IsIndexHome" 
                  Content="Use index.html as starting point"  
                  IsChecked="True" 
                  Margin="10,20,0,0" 
                  VerticalContentAlignment="Center"/>
  </StackPanel>
</Window>