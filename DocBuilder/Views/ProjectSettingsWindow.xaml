<Window x:Class="DocBuilder.Views.ProjectSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Settings" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
  <StackPanel Margin="20">
    <TextBlock Text="Brand Name" Margin="0,5"/>
    <TextBox Name="TxtBrandName" Padding="5"/>

    <TextBlock Text="Logo Path" Margin="0,15,0,5"/>
    <DockPanel>
      <Button Content="Browse" DockPanel.Dock="Right" Click="BrowseLogo_Click" Padding="10,0"/>
      <TextBox Name="TxtLogoPath" Padding="5"/>
    </DockPanel>

    <TextBlock Text="Output Directory" Margin="0,15,0,5"/>
    <TextBox Name="TxtOutputPath" IsReadOnly="True" Background="#F0F0F0" Padding="5"/>

    <UniformGrid Columns="2" Margin="0,30,0,0">
      <Button Content="Save Changes" Click="Save_Click" Margin="5" Padding="10"/>
      <Button Content="Cancel" IsCancel="True" Margin="5" Padding="10"/>
    </UniformGrid>
  </StackPanel>
</Window>