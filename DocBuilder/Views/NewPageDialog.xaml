<Window x:Class="DocBuilder.Views.NewPageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Page" Height="220" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F7">
  <StackPanel Margin="25">
    <TextBlock Text="Page Title" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
    <TextBox x:Name="TxtTitle" Padding="8" FontSize="14" 
                 BorderBrush="#CBD5E0" BorderThickness="1" 
                 GotFocus="TxtTitle_GotFocus"/>

    <TextBlock Text="This title will be used for the sidebar and filename." 
                   FontSize="11" Foreground="#718096" Margin="0,5,0,20"/>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" IsCancel="True" Width="80" Margin="0,0,10,0" 
                    Background="Transparent" BorderThickness="0" Cursor="Hand"/>
      <Button Content="Create Page" Click="Create_Click" Width="110" 
                    Background="#667eea" Foreground="White" FontWeight="Bold" Cursor="Hand">
        <Button.Resources>
          <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
          </Style>
        </Button.Resources>
      </Button>
    </StackPanel>
  </StackPanel>
</Window>